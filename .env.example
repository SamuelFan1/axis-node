AXIS_NODE_SERVER_URL=http://127.0.0.1:9090
AXIS_NODE_MANAGEMENT_ADDRESS=10.8.1.11:9090
AXIS_NODE_REGION=sgp

# 可选：默认不配置，axis-node 会优先使用 systemd 注入的宿主机主机名
# 如果未通过 systemd 运行，则回退到 os.Hostname()
# AXIS_NODE_HOSTNAME=sgp-edge-01

AXIS_NODE_STATUS=up
AXIS_NODE_UUID_FILE=./data/node-uuid
AXIS_NODE_REPORT_INTERVAL_SEC=10
# 磁盘路径仅作兼容保留，实际会采集全部挂载点
AXIS_NODE_DISK_PATH=/
AXIS_NODE_SHARED_TOKEN=change_me_node_token
