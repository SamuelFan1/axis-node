AXIS_NODE_SERVER_URL=http://127.0.0.1:19090
AXIS_NODE_MANAGEMENT_ADDRESS=10.8.1.11:9090
AXIS_NODE_REGION=asia
AXIS_NODE_ZONE=SG

# AXIS_NODE_REGION: 大洲，如 asia, europe, australia, north_america, south_america
# AXIS_NODE_ZONE: 可用区，ISO-3166-1 alpha-2 国家代码，如 SG, CN, US

# 可选：默认不配置，axis-node 会优先使用 systemd 注入的宿主机主机名
# 如果未通过 systemd 运行，则回退到 os.Hostname()
# AXIS_NODE_HOSTNAME=sgp-edge-01

AXIS_NODE_STATUS=up
AXIS_NODE_UUID_FILE=/data/axis-node/node-uuid
AXIS_NODE_REPORT_INTERVAL_SEC=10
# 磁盘路径仅作兼容保留，实际会采集全部挂载点
AXIS_NODE_DISK_PATH=/
# 可选监控 provider：默认开启，可显式关闭
AXIS_NODE_MONITORING_ENABLED=true
AXIS_NODE_MONITORING_GO_SIDECAR_ENABLED=true
AXIS_NODE_MONITORING_CF_TUNNEL_ENABLED=false
# 仅在启用 go-sidecar provider 时生效
AXIS_NODE_SIDECAR_STATS_URL=http://127.0.0.1:8086/api/v1/internal/workload-stats
AXIS_NODE_SIDECAR_STATS_TIMEOUT_SEC=3
# 仅在启用 Cloudflare Tunnel provider 时生效
AXIS_NODE_MONITORING_CF_TUNNEL_SERVICE_NAME=cloudflared
AXIS_NODE_MONITORING_CF_TUNNEL_MONITOR_SERVICE_NAME=cloudflared-health-monitor
AXIS_NODE_MONITORING_CF_TUNNEL_HEALTH_URL=http://localhost:8085/health/
AXIS_NODE_MONITORING_CF_TUNNEL_TIMEOUT_SEC=3
AXIS_NODE_SHARED_TOKEN=change_me_node_token

# DNS 自动化如果需要，请在 Axis 管理平面的 .env 中配置。
# axis-node 只负责上报 public_ip，不需要配置 Cloudflare Token、Zone 或记录前缀。
